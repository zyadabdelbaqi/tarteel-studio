```json
{
  "rewrites": [
    {
      "source": "/surah-:name-video",
      "destination": "/seo-pages/surah-:name-video.html"
    },
    {
      "source": "/quran-video-maker",
      "destination": "/seo-pages/usecase-pages/quran-video-maker.html"
    },
    {
      "source": "/islamic-video-maker",
      "destination": "/seo-pages/usecase-pages/islamic-video-maker.html"
    },
    {
      "source": "/quran-reels-maker",
      "destination": "/seo-pages/usecase-pages/quran-reels-maker.html"
    },
    {
      "source": "/create-quran-video",
      "destination": "/seo-pages/usecase-pages/create-quran-video.html"
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/ffmpeg/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/js/lib/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000"
        }
      ]
    },
    {
      "source": "/video/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
